			"type": "string"
		}
	],
	"item": [
		{
			"name": "Public — List Products (no token)",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/products",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "products"]
				},
				"description": "D010 — Public endpoint, token gerektirmez. 200 dönmeli."
			},
			"response": []
		},
		{
			"name": "Protected — Create Product (no token → 401)",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Test Product\",\n  \"price\": 99.90,\n  \"stock\": 10,\n  \"sku\": \"TST-001\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/products",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "products"]
				},
				"description": "Token olmadan korumalı endpoint. 401 Unauthorized dönmeli."
			},
			"response": []
		},
		{
			"name": "Protected — Create Product (with token → 201)",
			"request": {
				"auth": {
					"type": "oauth2"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Token Test Product\",\n  \"price\": 149.90,\n  \"stock\": 25,\n  \"sku\": \"TKN-001\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/products",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "products"]
				},
				"description": "Collection'dan miras alınan OAuth2 token ile. 201 Created dönmeli.\n\nÖnce collection Authorization sekmesinden \"Get New Access Token\" ile token al."
			},
			"response": []
		},
		{
			"name": "OIDC Discovery",
