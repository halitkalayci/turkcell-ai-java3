					"protocol": "http",
					"host": ["localhost"],
					"port": "9000",
					"path": [".well-known", "openid-configuration"]
				},
				"description": "auth-service OIDC discovery endpoint. Sunucu ayaktaysa JSON döner."
			},
			"response": []
		}
	]
