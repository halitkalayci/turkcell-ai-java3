				"value": "auth-service-token",
				"type": "string"
			},
			{
				"key": "authUrl",
				"value": "http://localhost:9000/oauth2/authorize",
				"type": "string"
			},
			{
				"key": "accessTokenUrl",
				"value": "http://localhost:9000/oauth2/token",
				"type": "string"
			},
			{
				"key": "clientId",
				"value": "mini-ecommerce-client",
				"type": "string"
			},
			{
				"key": "clientSecret",
				"value": "secret",
				"type": "string"
			},
			{
				"key": "scope",
